# Vite 会把 /api 代理到下面这个地址（默认 8788 = 本地 wrangler）
VITE_API_PROXY=http://127.0.0.1:8788

# 若不想本地跑 Functions，可直接指向线上（复制为 .env 后重启 npm run dev）
# VITE_API_PROXY=https://creativevideo.net

# 本地 wrangler 测续费提醒 cron（需与 wrangler.toml / secrets 中 CRON_SECRET 一致）：
# curl -H "Authorization: Bearer YOUR_CRON_SECRET" http://127.0.0.1:8788/api/cron/subscription-reminders
